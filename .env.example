# ============================================
# AI 服务配置
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Supabase 数据库配置
# ============================================
# 本地开发：只需配置 SUPABASE_URL 即可
# Vercel 部署：需要在 Vercel Dashboard 中配置 VITE_SUPABASE_URL
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# 应用 URL 配置
# ============================================
# 生产环境的站点 URL（用于邮件重置链接）
# 本地开发留空，会自动使用 localhost
# Vercel 部署时设置为：https://www.vocab-monster.xyz
VITE_APP_URL=

# ============================================
# Vercel 环境变量配置（重要！）
# ============================================
# 部署到 Vercel 时，必须在 Dashboard 中添加以下环境变量：
#
#   名称: VITE_SUPABASE_URL
#   值: https://your-project.supabase.co
#   环境: Production ✅  Preview ✅  Development ✅
#
#   名称: VITE_SUPABASE_ANON_KEY
#   值: your_supabase_anon_key_here
#   环境: All
#
# 📌 配置步骤：
# 1. 访问 Vercel 项目 Settings → Environment Variables
# 2. 添加上述两个变量（必须以 VITE_ 开头）
# 3. 重新部署应用
#
# 详细说明：docs/vercel-env-setup.md

# ============================================
# 分层 AI 提供商配置 (gemini | openai)
# ============================================
IMAGE_GEN_PROVIDER=gemini
IMAGE_GEN_API_KEY=
IMAGE_GEN_ENDPOINT=

TTS_PROVIDER=gemini
TTS_API_KEY=
TTS_ENDPOINT=

OCR_PROVIDER=gemini
OCR_API_KEY=
OCR_ENDPOINT=

SPELLING_CHECK_PROVIDER=gemini
SPELLING_CHECK_API_KEY=
SPELLING_CHECK_ENDPOINT=

STT_PROVIDER=gemini
STT_API_KEY=
STT_ENDPOINT=

# ============================================
# 全局默认配置
# ============================================
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
OPENAI_ENDPOINT=https://api.openai.com/v1

# ============================================
# MiniMax TTS（服务端）
# ============================================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_VOICE_ID=Serene_Woman
MINIMAX_TTS_SPEED=0.95
MINIMAX_TTS_PITCH=0
MINIMAX_TTS_VOL=1
MINIMAX_TTS_AUDIO_FORMAT=mp3
MINIMAX_TTS_SAMPLE_RATE=16000
MINIMAX_TTS_BITRATE=32000
MINIMAX_TTS_CHANNEL=1
MINIMAX_TTS_ENDPOINT=https://api-bj.minimaxi.com/v1/t2a_v2
